{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "app-blueprint values",
  "description": "Configuration schema for the app-blueprint Helm chart.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "replicaCount": { "type": "integer", "minimum": 0 },
    "revisionHistoryLimit": { "type": "integer", "minimum": 0 },
    "nameOverride": { "type": "string" },
    "fullnameOverride": { "type": "string" },
    "appVersionOverride": { "type": "string", "maxLength": 63 },
    "image": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "tag", "digest", "pullPolicy"],
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "tag": { "type": "string" },
        "digest": { "type": "string", "pattern": "^$|^sha256:[a-fA-F0-9]{64}$" },
        "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] }
      }
    },
    "imagePullSecrets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": { "name": { "type": "string", "minLength": 1 } }
      }
    },
    "deployment": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "annotations": { "type": "object" },
        "strategy": { "type": "object" }
      }
    },
    "podAnnotations": { "type": "object" },
    "podLabels": { "type": "object" },
    "podSecurityContext": { "type": "object" },
    "securityContext": { "type": "object" },
    "serviceAccount": {
      "type": "object",
      "additionalProperties": false,
      "required": ["create", "automount", "annotations", "name"],
      "properties": {
        "create": { "type": "boolean" },
        "automount": { "type": "boolean" },
        "annotations": { "type": "object" },
        "name": { "type": "string" }
      }
    },
    "container": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "command": { "type": "array", "items": { "type": "string" } },
        "args": { "type": "array", "items": { "type": "string" } },
        "workingDir": { "type": "string" },
        "ports": {
          "type": "object",
          "minProperties": 1,
          "propertyNames": { "pattern": "^[a-z]([-a-z0-9]{0,13}[a-z0-9])?$" },
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "required": ["containerPort"],
            "properties": {
              "containerPort": { "type": "integer", "minimum": 1, "maximum": 65535 },
              "protocol": { "type": "string", "enum": ["TCP", "UDP", "SCTP"] }
            }
          }
        },
        "lifecycle": { "type": "object" }
      }
    },
    "configMap": {
      "type": "object",
      "additionalProperties": false,
      "required": ["create", "name", "data"],
      "properties": {
        "create": { "type": "boolean" },
        "name": { "type": "string" },
        "data": { "type": "object" }
      }
    },
    "secret": {
      "type": "object",
      "additionalProperties": false,
      "required": ["create", "name", "existingSecret", "stringData"],
      "properties": {
        "create": { "type": "boolean" },
        "name": { "type": "string" },
        "existingSecret": { "type": "string" },
        "stringData": { "type": "object" }
      },
      "not": {
        "properties": {
          "create": { "const": true },
          "existingSecret": { "minLength": 1 }
        },
        "required": ["create", "existingSecret"]
      }
    },
    "env": { "type": "array", "items": { "type": "object" } },
    "envFrom": { "type": "array", "items": { "type": "object" } },
    "service": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "type", "annotations", "ports"],
      "properties": {
        "enabled": { "type": "boolean" },
        "type": { "type": "string", "enum": ["ClusterIP", "NodePort", "LoadBalancer", "ExternalName"] },
        "annotations": { "type": "object" },
        "ports": {
          "type": "object",
          "minProperties": 1,
          "propertyNames": { "pattern": "^[a-z]([-a-z0-9]{0,13}[a-z0-9])?$" },
          "additionalProperties": {
            "type": "object",
            "required": ["port", "targetPort"],
            "properties": {
              "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
              "targetPort": { "anyOf": [{ "type": "integer" }, { "type": "string" }] },
              "protocol": { "type": "string", "enum": ["TCP", "UDP", "SCTP"] },
              "appProtocol": { "type": "string" }
            }
          }
        }
      }
    },
    "ingress": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "className", "annotations", "hosts", "tls"],
      "properties": {
        "enabled": { "type": "boolean" },
        "className": { "type": "string" },
        "annotations": { "type": "object" },
        "hosts": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["host", "paths"],
            "properties": {
              "host": { "type": "string", "minLength": 1 },
              "paths": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": ["path", "pathType", "servicePort"],
                  "properties": {
                    "path": { "type": "string" },
                    "pathType": { "type": "string", "enum": ["Exact", "Prefix", "ImplementationSpecific"] },
                    "servicePort": { "type": "string" }
                  }
                }
              }
            }
          }
        },
        "tls": { "type": "array", "items": { "type": "object" } }
      }
    },
    "probes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["startup", "readiness", "liveness"],
      "properties": {
        "startup": { "$ref": "#/definitions/probe" },
        "readiness": { "$ref": "#/definitions/probe" },
        "liveness": { "$ref": "#/definitions/probe" }
      }
    },
    "resources": { "type": "object" },
    "autoscaling": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "minReplicas", "maxReplicas", "targetCPUUtilizationPercentage", "targetMemoryUtilizationPercentage"],
      "properties": {
        "enabled": { "type": "boolean" },
        "minReplicas": { "type": "integer", "minimum": 1 },
        "maxReplicas": { "type": "integer", "minimum": 1 },
        "targetCPUUtilizationPercentage": { "anyOf": [{ "type": "integer", "minimum": 1, "maximum": 100 }, { "type": "string", "maxLength": 0 }] },
        "targetMemoryUtilizationPercentage": { "anyOf": [{ "type": "integer", "minimum": 1, "maximum": 100 }, { "type": "string", "maxLength": 0 }] }
      }
    },
    "podDisruptionBudget": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "minAvailable": { "anyOf": [{ "type": "integer" }, { "type": "string" }] },
        "maxUnavailable": { "anyOf": [{ "type": "integer" }, { "type": "string" }] }
      }
    },
    "nodeSelector": { "type": "object" },
    "tolerations": { "type": "array", "items": { "type": "object" } },
    "affinity": { "type": "object" },
    "topologySpreadConstraints": { "type": "array", "items": { "type": "object" } },
    "initContainers": { "type": "array", "items": { "type": "object" } },
    "sidecars": { "type": "array", "items": { "type": "object" } },
    "volumes": { "type": "array", "items": { "type": "object" } },
    "volumeMounts": { "type": "array", "items": { "type": "object" } },
    "persistence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "existingClaim", "mountPath", "subPath", "accessModes", "size", "storageClass", "annotations"],
      "properties": {
        "enabled": { "type": "boolean" },
        "existingClaim": { "type": "string" },
        "mountPath": { "type": "string", "minLength": 1 },
        "subPath": { "type": "string" },
        "accessModes": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "size": { "type": "string", "pattern": "^[0-9]+(Ei|Pi|Ti|Gi|Mi|Ki|E|P|T|G|M|K)?$" },
        "storageClass": { "type": "string" },
        "annotations": { "type": "object" }
      }
    },
    "migration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "command", "args", "annotations", "backoffLimit", "activeDeadlineSeconds", "resources", "hook"],
      "properties": {
        "enabled": { "type": "boolean" },
        "command": { "type": "array", "items": { "type": "string" } },
        "args": { "type": "array", "items": { "type": "string" } },
        "annotations": { "type": "object" },
        "backoffLimit": { "type": "integer", "minimum": 0 },
        "activeDeadlineSeconds": { "type": "integer", "minimum": 1 },
        "resources": { "type": "object" },
        "hook": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled", "events", "weight", "deletePolicy"],
          "properties": {
            "enabled": { "type": "boolean" },
            "events": { "type": "string" },
            "weight": { "type": "string" },
            "deletePolicy": { "type": "string" }
          }
        }
      }
    },
    "networkPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "policyTypes", "ingress", "egress"],
      "properties": {
        "enabled": { "type": "boolean" },
        "policyTypes": { "type": "array", "items": { "type": "string", "enum": ["Ingress", "Egress"] } },
        "ingress": { "type": "array", "items": { "type": "object" } },
        "egress": { "type": "array", "items": { "type": "object" } }
      }
    },
    "extraObjects": { "type": "array", "items": { "type": "object" } },
    "tests": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "image", "servicePort", "path"],
      "properties": {
        "enabled": { "type": "boolean" },
        "image": { "type": "string", "minLength": 1 },
        "servicePort": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "pattern": "^/" }
      }
    }
  },
  "required": ["replicaCount", "image", "container", "service", "probes"],
  "definitions": {
    "probe": {
      "type": "object",
      "required": ["enabled"],
      "properties": { "enabled": { "type": "boolean" } },
      "additionalProperties": true
    }
  }
}
